#!/system/bin/sh
# File: /data/adb/QTUN/scripts/qtun.service

MODDIR="/data/adb/QTUN"
RUNDIR="$MODDIR/run"
TOOL="$MODDIR/scripts/qtun.tool"
QTUN_LOG="$RUNDIR/qtun.log"
RUN_LOG="$RUNDIR/run.log"

# Pastikan folder run tersedia
mkdir -p "$RUNDIR"

log_service() {
    echo "[$(date '+%H:%M:%S')] [SERVICE] $1" >> "$RUN_LOG"
}

case "$1" in
  start)
    log_service "Starting QTUN Services..."
    
    # Jalankan tool (core), output diarahkan ke qtun.log
    $TOOL start > "$QTUN_LOG" 2>&1
    RETVAL=$?
    
    # Salin hasil eksekusi tool ke run.log untuk audit
    cat "$QTUN_LOG" >> "$RUN_LOG"

    if [ $RETVAL -eq 0 ]; then 
        echo "[QTUN] ZIVPN System is ONLINE."
        log_service "Status: ONLINE"
    else
        echo "[QTUN] FAILED to start. Check $QTUN_LOG"
        log_service "Status: FAILED"
        exit 1
    fi
    ;;
    
  stop)
    log_service "Stopping QTUN Services..."
    
    $TOOL stop >> "$QTUN_LOG" 2>&1
    cat "$QTUN_LOG" >> "$RUN_LOG"
    
    echo "[QTUN] ZIVPN System is OFFLINE."
    log_service "Status: OFFLINE"
    ;;
    
  status)
    $TOOL status
    ;;
    
  restart)
    $0 stop
    sleep 2
    $0 start
    ;;
    
  *)
    echo "Usage: $0 {start|stop|restart|status}"
    exit 1
    ;;
esac